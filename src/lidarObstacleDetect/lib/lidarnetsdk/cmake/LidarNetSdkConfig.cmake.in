@PACKAGE_INIT@

# Compute paths
get_filename_component(LidarNetSdk_CMAKE_DIR "${CMAKE_CURRENT_LIST_FILE}" PATH)
set(LidarNetSdk_INCLUDE_DIRS "@PACKAGE_CMAKE_INSTALL_INCLUDEDIR@")
set(LidarNetSdk_LIBRARY_DIRS "@PACKAGE_CMAKE_INSTALL_LIBDIR@")

# Our library dependencies (contains definitions for IMPORTED targets)
# include("${LidarNetSdk_CMAKE_DIR}/LidarNetSdk-targets.cmake")
file(GLOB LidarNetSdk_LIBRARIES_SO ${LidarNetSdk_LIBRARY_DIRS}/liblidar-net-sdk.so)
#file(GLOB LidarNetSdk_LIBRARIES_A ${LidarNetSdk_LIBRARY_DIRS}/*.a)
# These are IMPORTED targets created by yaml-cpp-targets.cmake
set(LidarNetSdk_LIBRARIES ${LidarNetSdk_LIBRARIES_SO})
#set(LidarNetSdk_LIBRARIES_STATIC ${LidarNetSdk_LIBRARIES_A})
